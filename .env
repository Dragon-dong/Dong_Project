# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=cross_modal_system

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# API配置
API_KEY=your_api_key_here
DEBUG=True

# 模型配置
MODEL_CACHE_DIR=./models
MAX_GENERATION_SIZE=1024
TIMEOUT=30

# 图片生成配置
IMAGE_WIDTH=512
IMAGE_HEIGHT=512
IMAGE_QUALITY=95

# 安全配置
SECRET_KEY=your_secret_key_here
ALLOWED_ORIGINS=*

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=app.log